// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AulaStatus {
  ABERTA
  FINALIZADA
}

model Aluno {
  id                Int              @id @default(autoincrement())

  nome              String
  apelido           String?
  dataNascimento    DateTime

  sexo              String?
  cpf               String?
  rg                String?

  telefone          String?
  whatsapp          String?
  email             String?

  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  uf                String?

  escola            String?
  serieEscolar      String?
  turnoEscolar      String?

  peso              Float?
  altura            Float?

  tamanhoKimono     String?
  marcaKimono       String?

  restricoesMedicas String?
  alergias          String?
  medicamentos      String?
  observacoes       String?

  fotoUrl           String?

  faixa             String           @default("Branca")
  grau              Int              @default(0)
  ativo             Boolean          @default(true)

  responsaveis      Responsavel[]
  mensalidades      Mensalidade[]
  graduacoes        Graduacao[]
  aulas             AulaAluno[]
  competicoes       CompeticaoAluno[]
  comportamentos    Comportamento[]

  turmaId           Int?
  turma             Turma?           @relation(fields: [turmaId], references: [id])

  formaPagamento    String?
  diaVencimento     Int?

  planoId           Int?
  plano             Plano?           @relation(fields: [planoId], references: [id])

  createdAt         DateTime         @default(now())
  //updatedAt         DateTime         @updatedAt
  updatedAt DateTime @default(now()) @updatedAt
}

model Responsavel {
  id                     Int      @id @default(autoincrement())

  nome                   String
  apelido                String?

  cpf                    String?
  rg                     String?
  dataNascimento         DateTime?
  sexo                   String?

  telefone               String?
  whatsapp               String?
  email                  String?

  cep                    String?
  logradouro             String?
  numero                 String?
  complemento            String?
  bairro                 String?
  cidade                 String?
  uf                     String?

  parentesco             String   @default("Não informado")

  responsavelFinanceiro  Boolean  @default(false)
  podeBuscar             Boolean  @default(true)
  contatoEmergencia      Boolean  @default(false)
  recebeComunicados      Boolean  @default(true)

  observacoes            String?
  fotoUrl                String?

  ativo                  Boolean  @default(true)

  alunoId                Int
  aluno                  Aluno    @relation(fields: [alunoId], references: [id])

  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt
}

model Mensalidade {
  id             Int       @id @default(autoincrement())
  valor          Float
  vencimento     DateTime
  dataPagamento  DateTime?
  pago           Boolean   @default(false)
  descricao      String?

  alunoId        Int
  aluno          Aluno     @relation(fields: [alunoId], references: [id])
}

model Graduacao {
  id          Int       @id @default(autoincrement())
  faixa       String
  data        DateTime

  alunoId     Int
  aluno       Aluno     @relation(fields: [alunoId], references: [id])
}

model AulaAluno {
  id          Int      @id @default(autoincrement())

  aulaId      Int
  aula        Aula     @relation(fields: [aulaId], references: [id])

  alunoId     Int
  aluno       Aluno    @relation(fields: [alunoId], references: [id])

  presente    Boolean  @default(false)

  respeito    Boolean  @default(false)
  valentia    Boolean  @default(false)
  esforco     Boolean  @default(false)
  atencao     Boolean  @default(false)
  disciplina  Boolean  @default(false)

  observacao  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([aulaId, alunoId])
}

model Competicao {
  id          Int                 @id @default(autoincrement())
  nome        String
  data        DateTime
  local       String

  atletas     CompeticaoAluno[]
}

model CompeticaoAluno {
  id              Int          @id @default(autoincrement())

  competicaoId    Int
  alunoId         Int

  resultado       String?

  competicao      Competicao   @relation(fields: [competicaoId], references: [id])
  aluno           Aluno        @relation(fields: [alunoId], references: [id])
}

model Comportamento {
  id          Int      @id @default(autoincrement())

  alunoId     Int
  aluno       Aluno    @relation(fields: [alunoId], references: [id])

  respeito    Int
  valentia    Int
  esforco     Int
  atencao     Int
  disciplina  Int

  observacao  String?

  createdAt   DateTime @default(now())
}

model Turma {
  id            Int      @id @default(autoincrement())

  nome          String
  faixaEtaria   String

  diasSemana    String
  horarioInicio String
  horarioFim    String

  professorId   Int?
  professor     Usuario? @relation(fields: [professorId], references: [id])

  limiteAlunos  Int?

  ativo         Boolean  @default(true)

  curriculoId   Int?
  curriculo     Curriculo? @relation(fields: [curriculoId], references: [id])

  alunos        Aluno[]
  aulas         Aula[]
  aulasProgramadas AulaProgramada[]

  createdAt     DateTime @default(now())

 
}

model Usuario {
  id                Int      @id @default(autoincrement())

  nome              String
  apelido           String?
  email             String   @unique
  senha             String

  perfil            String

  nivelGraduacao    String?
  outrasGraduacoes  String?

  fotoUrl           String?

  ativo             Boolean  @default(true)

  turmas            Turma[]
  avisosReconhecidos AvisoReconhecido[]

  createdAt         DateTime @default(now())
}

model AvisoReconhecido {
  id           Int      @id @default(autoincrement())

  usuarioId    Int
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])

  tipo         String
  referenciaId Int

  criadoEm     DateTime @default(now())

  @@unique([usuarioId, tipo, referenciaId])
}

model Plano {
  id            Int      @id @default(autoincrement())

  nome          String
  valor         Float
  periodicidade String

  ativo         Boolean  @default(true)

  alunos        Aluno[]

  createdAt     DateTime @default(now())
}

model Aula {
  id          Int       @id @default(autoincrement())

  data        DateTime
  professor   String?
  observacoes String?

  turmaId     Int?
  turma       Turma?    @relation(fields: [turmaId], references: [id])

  aulaCurriculoId Int?
  aulaCurriculo   AulaCurriculo? @relation(fields: [aulaCurriculoId], references: [id])
  programacao AulaProgramada?

  alunos      AulaAluno[]

  jogosRealizados    String[]           @default([])
  tecnicasRealizadas TecnicaCurriculo[] @relation("AulaTecnicasRealizadas")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  status AulaStatus @default(ABERTA)
}

model Tecnica {
  id              Int      @id @default(autoincrement())

  nome            String

  categoria       String
  subCategoria    String?

  descricao       String?

  faixaMinima     String?
  idadeMinima     Int?

  nivel           String?

  ordemCurriculo  Int?

  ativa           Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model Curriculo {
  id          Int      @id @default(autoincrement())

  nome        String
  descricao   String?
  modalidade  String   @default("Jiu-Jitsu")
  publico     String   @default("Kids")

  ativo       Boolean  @default(true)

  modulos     ModuloCurriculo[]
  turmas      Turma[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model ModuloCurriculo {
  id            Int      @id @default(autoincrement())

  nome          String
  descricao     String?

  faixa         String?
  idadeMinima   Int?
  idadeMaxima   Int?

  ordem         Int      @default(0)

  curriculoId   Int
  curriculo     Curriculo @relation(fields: [curriculoId], references: [id])

  aulas         AulaCurriculo[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model AulaCurriculo {
  id              Int      @id @default(autoincrement())

  titulo          String
  objetivo        String?
  descricao       String?
  duracaoMinutos  Int?
  jogosSugeridos  String?

  ordem           Int      @default(0)

  moduloId        Int
  modulo          ModuloCurriculo @relation(fields: [moduloId], references: [id])

  tecnicas        TecnicaCurriculo[]
  aulasRealizadas Aula[]
  programacoes    AulaProgramada[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model TecnicaCurriculo {
  id              Int      @id @default(autoincrement())

  nome            String
  categoria       String?
  descricao       String?

  obrigatoria     Boolean  @default(true)
  ordem           Int      @default(0)

  aulaCurriculoId Int
  aulaCurriculo   AulaCurriculo @relation(fields: [aulaCurriculoId], references: [id])

  aulasQueRealizaram Aula[] @relation("AulaTecnicasRealizadas")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model AulaProgramada {
  id              Int      @id @default(autoincrement())

  turmaId         Int
  turma           Turma    @relation(fields: [turmaId], references: [id])

  aulaCurriculoId Int?
  aulaCurriculo   AulaCurriculo? @relation(fields: [aulaCurriculoId], references: [id])

  data            DateTime
  observacoes     String?

  status          String   @default("PENDENTE")

  aulaId          Int?     @unique
  aula            Aula?    @relation(fields: [aulaId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}